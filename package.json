{
  "name": "tanstarter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vite dev --port 3000 --host'",
    "dev:old2": "tmux split-pane -h \\; send-keys 'pnpm dev:web' C-m \\; select-pane -t 0 \\; send-keys 'pnpm dev:db' C-m",
    "dev:old": "concurrently -r pnpm:dev:web pnpm:dev:db",
    "dev:web": "vite dev --port 3000 --host",
    "dev:db": "pnpx convex dev --live-component-sources --typecheck-components",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint --type-aware --type-check",
